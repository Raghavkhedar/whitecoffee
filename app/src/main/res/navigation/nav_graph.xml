<?xml version="1.0" encoding="utf-8"?>
<navigation
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- ── Login ── -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.raghav.whitecoffee.ui.login.LoginFragment"
        android:label="Login">
        <action
            android:id="@+id/action_loginFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- ── Home ── -->
    <fragment
        android:id="@+id/homeFragment"
        android:name="com.raghav.whitecoffee.ui.home.HomeFragment"
        android:label="Home">
        <action
            android:id="@+id/action_homeFragment_to_attendanceFragment"
            app:destination="@id/attendanceFragment" />
        <action
            android:id="@+id/action_homeFragment_to_materialToolRequestFragment"
            app:destination="@id/materialToolRequestFragment" />
        <action
            android:id="@+id/action_homeFragment_to_materialToolBuyFragment"
            app:destination="@id/materialToolBuyFragment" />
        <action
            android:id="@+id/action_homeFragment_to_materialTransferFragment"
            app:destination="@id/materialTransferFragment" />
        <action
            android:id="@+id/action_homeFragment_to_toolTransferFragment"
            app:destination="@id/toolTransferFragment" />
        <action
            android:id="@+id/action_homeFragment_to_workProgressFragment"
            app:destination="@id/workProgressFragment" />
        <action
            android:id="@+id/action_homeFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/homeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- ── Attendance ── -->
    <fragment
        android:id="@+id/attendanceFragment"
        android:name="com.raghav.whitecoffee.ui.attendance.AttendanceFragment"
        android:label="Attendance" />

    <!-- ── M&T Request ── -->
    <fragment
        android:id="@+id/materialToolRequestFragment"
        android:name="com.raghav.whitecoffee.ui.requests.MaterialToolRequestFragment"
        android:label="M&amp;T Request" />

    <!-- ── M&T Buy ── -->
    <fragment
        android:id="@+id/materialToolBuyFragment"
        android:name="com.raghav.whitecoffee.ui.requests.MaterialToolBuyFragment"
        android:label="M&amp;T Buy" />

    <!-- ── Material Transfer ── -->
    <fragment
        android:id="@+id/materialTransferFragment"
        android:name="com.raghav.whitecoffee.ui.requests.MaterialTransferFragment"
        android:label="Material Transfer" />

    <!-- ── Tool Transfer ── -->
    <fragment
        android:id="@+id/toolTransferFragment"
        android:name="com.raghav.whitecoffee.ui.requests.ToolTransferFragment"
        android:label="Tool Transfer" />

    <!-- ── Work Progress ── -->
    <fragment
        android:id="@+id/workProgressFragment"
        android:name="com.raghav.whitecoffee.ui.requests.WorkProgressFragment"
        android:label="Work Progress" />

</navigation>