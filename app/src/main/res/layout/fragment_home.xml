<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <include
            layout="@layout/view_offline_banner"
            android:id="@+id/offline_banner"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ── Header ── -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/header"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header"
            android:paddingHorizontal="20dp"
            android:paddingTop="52dp"
            android:paddingBottom="28dp"
            app:layout_constraintTop_toBottomOf="@id/offline_banner"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tv_greeting"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Good morning,"
                android:textSize="14sp"
                android:textColor="#BBDEFB"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/layout_bell"/>

            <TextView
                android:id="@+id/tv_user_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Loading..."
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginTop="2dp"
                app:layout_constraintTop_toBottomOf="@id/tv_greeting"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toStartOf="@id/layout_bell"/>

            <!-- Bell icon + unread badge -->
            <FrameLayout
                android:id="@+id/layout_bell"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="4dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toStartOf="@id/btn_logout">

                <TextView
                    android:id="@+id/btn_bell"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:text="🔔"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

                <TextView
                    android:id="@+id/tv_bell_badge"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:textSize="9sp"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:background="@drawable/badge_red_bg"
                    android:layout_gravity="top|end"
                    android:visibility="gone"/>

            </FrameLayout>

            <TextView
                android:id="@+id/tv_role_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Operations"
                android:textSize="11sp"
                android:textColor="@color/white"
                android:background="@drawable/badge_bg"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:layout_marginTop="8dp"
                app:layout_constraintTop_toBottomOf="@id/tv_user_name"
                app:layout_constraintStart_toStartOf="parent"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_logout"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Logout"
                android:textColor="#BBDEFB"
                android:textSize="13sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ── Section Label ── -->
        <TextView
            android:id="@+id/tv_modules_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Quick Actions"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:textStyle="bold"
            android:letterSpacing="0.06"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            app:layout_constraintTop_toBottomOf="@id/header"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ══ Module Cards Grid ══════════════════════════════════════════════ -->

        <!-- Row 1: Attendance | M&T Request -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_attendance"
            style="@style/WC.CardView.NoPadding"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/tv_modules_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="@id/guideline_center">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <View
                    android:layout_width="4dp"
                    android:layout_height="0dp"
                    android:background="#1565C0"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/icon_attendance"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="📋"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:background="@drawable/icon_bg_blue"
                    android:layout_marginStart="20dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/tv_title_attendance"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Attendance"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintTop_toTopOf="@id/icon_attendance"
                    app:layout_constraintBottom_toTopOf="@+id/tv_sub_attendance"
                    app:layout_constraintStart_toEndOf="@id/icon_attendance"
                    app:layout_constraintEnd_toStartOf="@+id/tv_arrow_attendance"
                    app:layout_constraintVertical_chainStyle="packed"/>

                <TextView
                    android:id="@+id/tv_sub_attendance"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Daily check-in / out"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="5dp"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_title_attendance"
                    app:layout_constraintBottom_toBottomOf="@id/icon_attendance"
                    app:layout_constraintStart_toEndOf="@id/icon_attendance"
                    app:layout_constraintEnd_toStartOf="@id/tv_arrow_attendance"/>

                <TextView
                    android:id="@+id/tv_arrow_attendance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="22sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginEnd="18dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_mt_request"
            style="@style/WC.CardView.NoPadding"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="10dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/tv_modules_label"
            app:layout_constraintStart_toEndOf="@id/guideline_center"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <View
                    android:layout_width="4dp"
                    android:layout_height="0dp"
                    android:background="#EA580C"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/icon_mt_request"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="🔧"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:background="@drawable/icon_bg_orange"
                    android:layout_marginStart="20dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/tv_title_mt_request"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="M&amp;T Request"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintTop_toTopOf="@id/icon_mt_request"
                    app:layout_constraintBottom_toTopOf="@+id/tv_sub_mt_request"
                    app:layout_constraintStart_toEndOf="@id/icon_mt_request"
                    app:layout_constraintEnd_toStartOf="@+id/tv_arrow_mt_request"
                    app:layout_constraintVertical_chainStyle="packed"/>

                <TextView
                    android:id="@+id/tv_sub_mt_request"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Request materials &amp; tools"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="5dp"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_title_mt_request"
                    app:layout_constraintBottom_toBottomOf="@id/icon_mt_request"
                    app:layout_constraintStart_toEndOf="@id/icon_mt_request"
                    app:layout_constraintEnd_toStartOf="@id/tv_arrow_mt_request"/>

                <TextView
                    android:id="@+id/tv_arrow_mt_request"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="22sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginEnd="18dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Barrier 1 -->
        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_row1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="card_attendance,card_mt_request"/>

        <!-- Row 2: M&T Buy | Material Transfer -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_mt_buy"
            style="@style/WC.CardView.NoPadding"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/barrier_row1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="@id/guideline_center">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <View
                    android:layout_width="4dp"
                    android:layout_height="0dp"
                    android:background="#16A34A"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/icon_mt_buy"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="🛒"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:background="@drawable/icon_bg_green"
                    android:layout_marginStart="20dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/tv_title_mt_buy"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="M&amp;T Buy"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintTop_toTopOf="@id/icon_mt_buy"
                    app:layout_constraintBottom_toTopOf="@+id/tv_sub_mt_buy"
                    app:layout_constraintStart_toEndOf="@id/icon_mt_buy"
                    app:layout_constraintEnd_toStartOf="@+id/tv_arrow_mt_buy"
                    app:layout_constraintVertical_chainStyle="packed"/>

                <TextView
                    android:id="@+id/tv_sub_mt_buy"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Log site purchases"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="5dp"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_title_mt_buy"
                    app:layout_constraintBottom_toBottomOf="@id/icon_mt_buy"
                    app:layout_constraintStart_toEndOf="@id/icon_mt_buy"
                    app:layout_constraintEnd_toStartOf="@id/tv_arrow_mt_buy"/>

                <TextView
                    android:id="@+id/tv_arrow_mt_buy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="22sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginEnd="18dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_material_transfer"
            style="@style/WC.CardView.NoPadding"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/barrier_row1"
            app:layout_constraintStart_toEndOf="@id/guideline_center"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <View
                    android:layout_width="4dp"
                    android:layout_height="0dp"
                    android:background="#7C3AED"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/icon_material_transfer"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="📦"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:background="@drawable/icon_bg_purple"
                    android:layout_marginStart="20dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/tv_title_material_transfer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Material Transfer"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintTop_toTopOf="@id/icon_material_transfer"
                    app:layout_constraintBottom_toTopOf="@+id/tv_sub_material_transfer"
                    app:layout_constraintStart_toEndOf="@id/icon_material_transfer"
                    app:layout_constraintEnd_toStartOf="@+id/tv_arrow_material_transfer"
                    app:layout_constraintVertical_chainStyle="packed"/>

                <TextView
                    android:id="@+id/tv_sub_material_transfer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Transfer materials"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="5dp"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_title_material_transfer"
                    app:layout_constraintBottom_toBottomOf="@id/icon_material_transfer"
                    app:layout_constraintStart_toEndOf="@id/icon_material_transfer"
                    app:layout_constraintEnd_toStartOf="@id/tv_arrow_material_transfer"/>

                <TextView
                    android:id="@+id/tv_arrow_material_transfer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="22sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginEnd="18dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Barrier 2 -->
        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_row2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="card_mt_buy,card_material_transfer"/>

        <!-- Row 3: Tool Transfer | Work Progress -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_tool_transfer"
            style="@style/WC.CardView.NoPadding"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/barrier_row2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="@id/guideline_center">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <View
                    android:layout_width="4dp"
                    android:layout_height="0dp"
                    android:background="#0891B2"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/icon_tool_transfer"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="🔨"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:background="@drawable/icon_bg_teal"
                    android:layout_marginStart="20dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/tv_title_tool_transfer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Tool Transfer"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintTop_toTopOf="@id/icon_tool_transfer"
                    app:layout_constraintBottom_toTopOf="@+id/tv_sub_tool_transfer"
                    app:layout_constraintStart_toEndOf="@id/icon_tool_transfer"
                    app:layout_constraintEnd_toStartOf="@+id/tv_arrow_tool_transfer"
                    app:layout_constraintVertical_chainStyle="packed"/>

                <TextView
                    android:id="@+id/tv_sub_tool_transfer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Log tool movements"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="5dp"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_title_tool_transfer"
                    app:layout_constraintBottom_toBottomOf="@id/icon_tool_transfer"
                    app:layout_constraintStart_toEndOf="@id/icon_tool_transfer"
                    app:layout_constraintEnd_toStartOf="@id/tv_arrow_tool_transfer"/>

                <TextView
                    android:id="@+id/tv_arrow_tool_transfer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="22sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginEnd="18dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_work_progress"
            style="@style/WC.CardView.NoPadding"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="10dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/barrier_row2"
            app:layout_constraintStart_toEndOf="@id/guideline_center"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <View
                    android:layout_width="4dp"
                    android:layout_height="0dp"
                    android:background="#D97706"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/icon_work_progress"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="📊"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:background="@drawable/icon_bg_amber"
                    android:layout_marginStart="20dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/tv_title_work_progress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Work Progress"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintTop_toTopOf="@id/icon_work_progress"
                    app:layout_constraintBottom_toTopOf="@+id/tv_sub_work_progress"
                    app:layout_constraintStart_toEndOf="@id/icon_work_progress"
                    app:layout_constraintEnd_toStartOf="@+id/tv_arrow_work_progress"
                    app:layout_constraintVertical_chainStyle="packed"/>

                <TextView
                    android:id="@+id/tv_sub_work_progress"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Daily progress report"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="5dp"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_title_work_progress"
                    app:layout_constraintBottom_toBottomOf="@id/icon_work_progress"
                    app:layout_constraintStart_toEndOf="@id/icon_work_progress"
                    app:layout_constraintEnd_toStartOf="@id/tv_arrow_work_progress"/>

                <TextView
                    android:id="@+id/tv_arrow_work_progress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="22sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginEnd="18dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Barrier 3 -->
        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_row3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="bottom"
            app:constraint_referenced_ids="card_tool_transfer,card_work_progress"/>

        <!-- Row 4: Leave | Leave Approvals (admin only) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_leave"
            style="@style/WC.CardView.NoPadding"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="10dp"
            app:layout_constraintTop_toBottomOf="@id/barrier_row3"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="@id/guideline_center">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <View
                    android:layout_width="4dp"
                    android:layout_height="0dp"
                    android:background="#E11D48"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/icon_leave"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="🗓️"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:background="@drawable/icon_bg_rose"
                    android:layout_marginStart="20dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/tv_title_leave"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Leave"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintTop_toTopOf="@id/icon_leave"
                    app:layout_constraintBottom_toTopOf="@+id/tv_sub_leave"
                    app:layout_constraintStart_toEndOf="@id/icon_leave"
                    app:layout_constraintEnd_toStartOf="@+id/tv_arrow_leave"
                    app:layout_constraintVertical_chainStyle="packed"/>

                <TextView
                    android:id="@+id/tv_sub_leave"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Apply &amp; track leave"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="5dp"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_title_leave"
                    app:layout_constraintBottom_toBottomOf="@id/icon_leave"
                    app:layout_constraintStart_toEndOf="@id/icon_leave"
                    app:layout_constraintEnd_toStartOf="@id/tv_arrow_leave"/>

                <TextView
                    android:id="@+id/tv_arrow_leave"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="22sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginEnd="18dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_leave_approvals"
            style="@style/WC.CardView.NoPadding"
            android:layout_width="0dp"
            android:layout_height="90dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="10dp"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/barrier_row3"
            app:layout_constraintStart_toEndOf="@id/guideline_center"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <View
                    android:layout_width="4dp"
                    android:layout_height="0dp"
                    android:background="#047857"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/icon_leave_approvals"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="✅"
                    android:textSize="22sp"
                    android:gravity="center"
                    android:background="@drawable/icon_bg_emerald"
                    android:layout_marginStart="20dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"/>

                <TextView
                    android:id="@+id/tv_title_leave_approvals"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Leave Approvals"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintTop_toTopOf="@id/icon_leave_approvals"
                    app:layout_constraintBottom_toTopOf="@+id/tv_sub_leave_approvals"
                    app:layout_constraintStart_toEndOf="@id/icon_leave_approvals"
                    app:layout_constraintEnd_toStartOf="@+id/tv_arrow_leave_approvals"
                    app:layout_constraintVertical_chainStyle="packed"/>

                <TextView
                    android:id="@+id/tv_sub_leave_approvals"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Review pending requests"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="5dp"
                    android:layout_marginStart="14dp"
                    android:layout_marginEnd="8dp"
                    app:layout_constraintTop_toBottomOf="@id/tv_title_leave_approvals"
                    app:layout_constraintBottom_toBottomOf="@id/icon_leave_approvals"
                    app:layout_constraintStart_toEndOf="@id/icon_leave_approvals"
                    app:layout_constraintEnd_toStartOf="@id/tv_arrow_leave_approvals"/>

                <TextView
                    android:id="@+id/tv_arrow_leave_approvals"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="›"
                    android:textSize="22sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginEnd="18dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Center guideline for 2-column grid -->
        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/guideline_center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.5"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
