<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingVertical="10dp">

    <!-- Timeline dot -->
    <View
        android:id="@+id/timeline_dot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:background="@drawable/timeline_dot"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Timeline line below dot -->
    <View
        android:id="@+id/timeline_line"
        android:layout_width="2dp"
        android:layout_height="0dp"
        android:background="@color/border"
        app:layout_constraintTop_toBottomOf="@id/timeline_dot"
        app:layout_constraintStart_toStartOf="@id/timeline_dot"
        app:layout_constraintEnd_toEndOf="@id/timeline_dot"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Event type label -->
    <TextView
        android:id="@+id/tv_event_type"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:layout_marginStart="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/timeline_dot"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Time + location -->
    <TextView
        android:id="@+id/tv_event_detail"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginStart="16dp"
        android:layout_marginTop="2dp"
        app:layout_constraintTop_toBottomOf="@id/tv_event_type"
        app:layout_constraintStart_toEndOf="@id/timeline_dot"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>