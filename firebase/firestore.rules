rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────

    function isLoggedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return userRole() == 'admin';
    }

    // Portal access is an explicit per-user list of allowed tab PATHS
    // (`tabAccess: string[]` on the user doc; see admin/src/lib/portalAccess.ts).
    // The get() here hits the same user doc as userRole(), so it's cached — no extra
    // billed read. Each collection is unlocked only by the tab(s) that legitimately
    // use it, via the per-domain helpers below. User-management writes stay admin-only,
    // so a scoped manager can never create users or self-promote.
    function userTabs() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('tabAccess', []);
    }

    // Attendance events: read for the tabs that surface attendance; update (siteId/
    // visitType/workDoneCategories patch) only for Attendance + Manpower Utilisation Input.
    function canReadAttendance() {
      return userTabs().hasAny(['/attendance', '/working-hours-shortage-excess', '/ot-shortage', '/manpower-utilisation-input', '/regularization']);
    }
    function canWriteAttendance() {
      return userTabs().hasAny(['/attendance', '/manpower-utilisation-input']);
    }

    // Computed daily status: read for attendance/OT views; write for Attendance +
    // Regularization (the two tabs that set/adjust a day's status).
    function canReadAttendanceStatus() {
      return userTabs().hasAny(['/attendance', '/regularization', '/working-hours-shortage-excess', '/ot-shortage']);
    }
    function canWriteAttendanceStatus() {
      return userTabs().hasAny(['/attendance', '/regularization']);
    }

    // Planned shift windows: read for attendance/OT views; write only for Attendance.
    function canReadPlannedHours() {
      return userTabs().hasAny(['/attendance', '/working-hours-shortage-excess', '/ot-shortage']);
    }
    function canWritePlannedHours() {
      return userTabs().hasAny(['/attendance']);
    }

    // Per-day worked-hours record (Cloud Function writes; portal reads).
    function canReadDailyHours() {
      return userTabs().hasAny(['/ot-shortage', '/working-hours-shortage-excess', '/attendance']);
    }

    // OT approvals: read for attendance/OT/settlement views; write for Attendance +
    // OT & Shortage (the two tabs that grant/adjust OT).
    function canReadOtApprovals() {
      return userTabs().hasAny(['/attendance', '/ot-shortage', '/working-hours-shortage-excess', '/ot-settlements']);
    }
    function canWriteOtApprovals() {
      return userTabs().hasAny(['/attendance', '/ot-shortage']);
    }

    // Frozen monthly settlements: read + write for OT Settlements only.
    function canAccessSettlements() {
      return userTabs().hasAny(['/ot-settlements']);
    }

    // Holidays: any signed-in user may read; write for Attendance.
    function canWriteHolidays() {
      return userTabs().hasAny(['/attendance']);
    }

    // Leave approvals: read + status update for Leaves.
    function canAccessLeaves() {
      return userTabs().hasAny(['/leaves']);
    }

    // Regularization: read + status update for Regularization.
    function canAccessRegularization() {
      return userTabs().hasAny(['/regularization']);
    }

    // Submissions family (material_*, tool_transfers, work_progress, submission_edits):
    // read + admin-style status update for Submissions.
    function canAccessSubmissions() {
      return userTabs().hasAny(['/submissions']);
    }

    // Conveyance records + config rate lookup: read + write for Conveyance.
    function canAccessConveyance() {
      return userTabs().hasAny(['/conveyance']);
    }

    // Notification send log + admin-portal notification creation: for Notifications.
    function canAccessNotifications() {
      return userTabs().hasAny(['/notifications']);
    }

    // User profiles: any grantable tab needs to resolve employee names/IDs/rates,
    // so ANY of the ten grantable tabs unlocks a cross-user read (writes stay admin-only).
    function canReadUsers() {
      return userTabs().hasAny(['/working-hours-shortage-excess', '/leaves', '/regularization', '/attendance', '/ot-shortage', '/ot-settlements', '/manpower-utilisation-input', '/submissions', '/conveyance', '/notifications']);
    }

    // ── Separation of duties ─────────────────────────────────────────────
    // A scoped manager must never action their OWN record. Without this, holding a tab
    // is self-service: /leaves approves your own leave, /ot-shortage your own overtime,
    // /ot-settlements your own settlement cash, /attendance marks you Present. Each one
    // pays the holder real money with no second pair of eyes.
    //
    // ADMIN IS DELIBERATELY EXEMPT. An admin can already edit salaryRate directly, so
    // blocking their self-approval buys nothing, and a single-admin company would
    // otherwise be unable to approve the admin's own leave at all.
    function notSelf(userId) {
      return request.auth.uid != userId;
    }

    // Same rule for collectionGroup matches, where {userId} is not bound by the path.
    // Every such document carries a `userId` field identifying whose record it is.
    // Update-only: on create, `resource` is null.
    function notSelfDoc() {
      return resource.data.userId != request.auth.uid;
    }

    // Returns true if the write touches ONLY the given fields (and no others).
    function changedKeysWithin(allowed) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(allowed);
    }

    // True if a create payload does NOT assert an approved/rejected status.
    // Submission docs (material_*, tool_transfers, work_progress) omit `status`
    // entirely on create; an owner may only ever create work that is unreviewed.
    // Without this, an owner could self-approve by writing status:"approved" at
    // create time (the update rules already block flipping status post-create).
    function createdUnreviewed() {
      return !('status' in request.resource.data)
             || request.resource.data.status == 'pending';
    }

    // ── /users/{userId} — User profiles ──────────────────────────────────

    match /users/{userId} {
      // Users read their own profile; admin and any scoped manager holding a grantable
      // tab read all (managers resolve employee names/roles/rates across their tabs).
      allow read:   if isLoggedIn() && (isOwner(userId) || isAdmin() || canReadUsers());
      // Only admin can create users (via secondary Firebase app in UserRepository)
      allow create: if isLoggedIn() && isAdmin();
      // Admin can update any field. A user may update ONLY their own session/FCM
      // token fields — never role/salaryRate/etc. (prevents self-promotion to admin).
      allow update: if isLoggedIn() && (
        isAdmin() ||
        (isOwner(userId) && changedKeysWithin(['activeSessionToken', 'fcmToken']))
      );
      allow delete: if isLoggedIn() && isAdmin();

      // ── /attendance/{docId} ───────────────────────────────────────────
      match /attendance/{docId} {
        allow read:   if isLoggedIn() && (isOwner(userId) || isAdmin() || canReadAttendance());
        allow create: if isLoggedIn() && isOwner(userId);
        // Events are immutable once recorded EXCEPT the admin-filled Site ID, Visit
        // Type, and Work Done categories: ops type a free-text site name at check-in
        // and an admin (or a manager holding Attendance / Manpower Utilisation Input)
        // later patches `siteId` + `visitType` + `workDoneCategories` from the Manpower
        // Utilisation Input page (updateAttendanceSiteId). Restricting to these keeps the
        // event otherwise tamper-proof (timestamp/location/type stay immutable).
        allow update: if isLoggedIn() && (isAdmin() || canWriteAttendance()) && changedKeysWithin(['siteId', 'visitType', 'workDoneCategories']);
        // Admin-only same-day punch correction (Daily Activity page): an admin rewinds a
        // timeline by deleting erroneous trailing punches. Every deletion is snapshotted
        // into attendance_corrections below, so nothing is lost. Non-admins never delete.
        allow delete: if isLoggedIn() && isAdmin();
      }

      // ── /compensation/{docId} — pay, split off the user document ──────
      // Firestore rules are DOCUMENT-level: there is no field-level read control, so
      // while salaryRate/pfPercent/esiPercent/imprestPercent sat on users/{uid}, every
      // tab that reads a user doc merely to resolve a name (nine of the ten grantable
      // tabs, via canReadUsers) could also enumerate the whole company's pay. Moving pay
      // to its own document is the ONLY way to restrict it.
      //
      // The employee themselves is deliberately NOT granted read here — pay is shown to
      // them through the payroll exports, not the app, and isOwner would hand every
      // employee a live salary endpoint.
      match /compensation/{docId} {
        allow read:  if isLoggedIn() && (isAdmin() || canAccessSettlements());
        allow write: if isLoggedIn() && isAdmin();
      }

      // ── /attendance_corrections/{docId} ───────────────────────────────
      // Immutable audit log of admin punch corrections (see restoreAttendanceToEvent):
      // full snapshots of deleted punches + who/why. Admin-only; create + read only.
      match /attendance_corrections/{docId} {
        allow read, create: if isLoggedIn() && isAdmin();
        allow update, delete: if false;
      }

      // ── /material_requests/{docId} ────────────────────────────────────
      match /material_requests/{docId} {
        allow read:   if isLoggedIn() && (isOwner(userId) || isAdmin() || canAccessSubmissions());
        allow create: if isLoggedIn() && isOwner(userId) && createdUnreviewed();
        // Owner may ONLY patch photoUrls (post-upload); admin / a Submissions manager can
        // update status etc. Without this restriction an owner could flip their own status.
        // notSelf: a Submissions manager must not approve their own submitted work.
        allow update: if isLoggedIn() && (
          isAdmin() ||
          (canAccessSubmissions() && notSelf(userId)) ||
          (isOwner(userId) && changedKeysWithin(['photoUrls']))
        );
        allow delete: if false;
      }

      // ── /material_purchases/{docId} ───────────────────────────────────
      match /material_purchases/{docId} {
        allow read:   if isLoggedIn() && (isOwner(userId) || isAdmin() || canAccessSubmissions());
        allow create: if isLoggedIn() && isOwner(userId) && createdUnreviewed();
        // notSelf: a Submissions manager must not approve their own submitted work.
        allow update: if isLoggedIn() && (
          isAdmin() ||
          (canAccessSubmissions() && notSelf(userId)) ||
          (isOwner(userId) && changedKeysWithin(['photoUrls']))
        );
        allow delete: if false;
      }

      // ── /material_transfers/{docId} ───────────────────────────────────
      match /material_transfers/{docId} {
        allow read:   if isLoggedIn() && (isOwner(userId) || isAdmin() || canAccessSubmissions());
        allow create: if isLoggedIn() && isOwner(userId) && createdUnreviewed();
        // notSelf: a Submissions manager must not approve their own submitted work.
        allow update: if isLoggedIn() && (
          isAdmin() ||
          (canAccessSubmissions() && notSelf(userId)) ||
          (isOwner(userId) && changedKeysWithin(['photoUrls']))
        );
        allow delete: if false;
      }

      // ── /tool_transfers/{docId} ───────────────────────────────────────
      match /tool_transfers/{docId} {
        allow read:   if isLoggedIn() && (isOwner(userId) || isAdmin() || canAccessSubmissions());
        allow create: if isLoggedIn() && isOwner(userId) && createdUnreviewed();
        // notSelf: a Submissions manager must not approve their own submitted work.
        allow update: if isLoggedIn() && (
          isAdmin() ||
          (canAccessSubmissions() && notSelf(userId)) ||
          (isOwner(userId) && changedKeysWithin(['photoUrls']))
        );
        allow delete: if false;
      }

      // ── /work_progress/{docId} ────────────────────────────────────────
      match /work_progress/{docId} {
        allow read:   if isLoggedIn() && (isOwner(userId) || isAdmin() || canAccessSubmissions());
        allow create: if isLoggedIn() && isOwner(userId) && createdUnreviewed();
        // notSelf: a Submissions manager must not approve their own submitted work.
        allow update: if isLoggedIn() && (
          isAdmin() ||
          (canAccessSubmissions() && notSelf(userId)) ||
          (isOwner(userId) && changedKeysWithin(['photoUrls']))
        );
        allow delete: if false;
      }

      // ── /leave_requests/{docId} ───────────────────────────────────────
      match /leave_requests/{docId} {
        allow read:   if isLoggedIn() && (isOwner(userId) || isAdmin() || canAccessLeaves());
        // Must be created pending — a self-approved leave would otherwise be
        // counted as PL by the nightly computeDailyAttendanceStatus function.
        allow create: if isLoggedIn() && isOwner(userId)
                      && request.resource.data.status == 'pending';
        // Admin / a Leaves manager updates status (approved/rejected); the owner
        // (employee app) cannot change status, and a Leaves manager cannot approve
        // their OWN leave (notSelf) — that would be self-granted paid time off.
        allow update: if isLoggedIn() && (isAdmin() || (canAccessLeaves() && notSelf(userId)));
        allow delete: if false;
      }

      // ── /notifications/{docId} ────────────────────────────────────────
      match /notifications/{docId} {
        allow read:   if isLoggedIn() && isOwner(userId);
        // User's FcmService + admin portal sender (admin or a Notifications manager) can create
        allow create: if isLoggedIn() && (isOwner(userId) || isAdmin() || canAccessNotifications());
        // User marks as read; admin can also update
        allow update: if isLoggedIn() && (isOwner(userId) || isAdmin());
        allow delete: if false;
      }

      // ── /attendance_status/{date} ─────────────────────────────────────
      // Written by Cloud Function (Admin SDK) for office/admin users (auto),
      // and by admin portal for operations users (manual).
      match /attendance_status/{date} {
        allow read:  if isLoggedIn() && (isOwner(userId) || isAdmin() || canReadAttendanceStatus());
        // notSelf: a manager marking their OWN day Present/WO is direct payroll fraud.
        allow write: if isLoggedIn() && (isAdmin() || (canWriteAttendanceStatus() && notSelf(userId)));
      }

      // ── /planned_hours/{date} ─────────────────────────────────────────
      // Admin-set per-day shift window for operations employees. Read by the
      // employee (their app), the admin, and managers holding the attendance/OT tabs,
      // and written by managers holding Attendance.
      match /planned_hours/{date} {
        allow read:  if isLoggedIn() && (isOwner(userId) || isAdmin() || canReadPlannedHours());
        // notSelf: the shift window sets the OT/shortage baseline, and `otAuthorized`
        // turns a rest day into all-hours OT — a manager must not set their own.
        allow write: if isLoggedIn() && (isAdmin() || (canWritePlannedHours() && notSelf(userId)));
      }

      // ── /daily_hours/{date} ───────────────────────────────────────────
      // Per-day worked-hours record (planned/actual/shortage/OT) written by the
      // computeDailyAttendanceStatus Cloud Function (Admin SDK bypasses rules).
      // Readable by the employee, the admin, and managers holding the OT/hours tabs.
      match /daily_hours/{date} {
        allow read:  if isLoggedIn() && (isOwner(userId) || isAdmin() || canReadDailyHours());
        allow write: if isLoggedIn() && isAdmin();
      }

      // ── /ot_approvals/{date} ──────────────────────────────────────────
      // Admin-granted overtime (approveOt from the employee dashboard). Read by the
      // employee, admin, and managers holding the attendance/OT/settlement tabs; written
      // by managers holding Attendance or OT & Shortage.
      match /ot_approvals/{date} {
        allow read:  if isLoggedIn() && (isOwner(userId) || isAdmin() || canReadOtApprovals());
        // notSelf: granting your own overtime is granting yourself cash.
        allow write: if isLoggedIn() && (isAdmin() || (canWriteOtApprovals() && notSelf(userId)));
      }

      // ── /settlements/{month} ──────────────────────────────────────────
      // Frozen monthly OT/shortage/WO settlement (Settle & Lock on the OT Settlements
      // page). Read by the employee, admin, and managers holding OT Settlements, who also settle.
      match /settlements/{month} {
        allow read:  if isLoggedIn() && (isOwner(userId) || isAdmin() || canAccessSettlements());
        // notSelf: settlementCash lands straight in TOTAL DUE — the highest-value
        // self-deal in the system.
        allow write: if isLoggedIn() && (isAdmin() || (canAccessSettlements() && notSelf(userId)));
      }

      // ── /regularization_requests/{docId} ──────────────────────────────
      match /regularization_requests/{docId} {
        allow read:   if isLoggedIn() && (isOwner(userId) || isAdmin() || canAccessRegularization());
        // Must be created pending — only an admin (or Regularization manager) approval may
        // flip the linked attendance_status to Present (done via writeBatch in the portal).
        allow create: if isLoggedIn() && isOwner(userId)
                      && request.resource.data.status == 'pending';
        // notSelf: approving your own regularization flips your own day to Present.
        allow update: if isLoggedIn() && (isAdmin() || (canAccessRegularization() && notSelf(userId)));
        allow delete: if false;
      }
    }

    // ── collectionGroup — leave_requests (admin Leave Approvals screen) ──
    // Required for LeaveApprovalsViewModel which does collectionGroup("leave_requests")
    match /{path=**}/leave_requests/{docId} {
      allow read:   if isLoggedIn() && (isAdmin() || canAccessLeaves());
      // notSelfDoc mirrors the per-doc notSelf guard: this collectionGroup path is a
      // second door onto the same documents, so leaving it unguarded would defeat the
      // per-doc rule entirely (the Android approvals screen writes through here).
      allow update: if isLoggedIn() && (isAdmin() || (canAccessLeaves() && notSelfDoc()));
    }

    // ── collectionGroup — admin portal Attendance & Submissions screens ──
    // A per-subcollection match (e.g. /users/{userId}/attendance/{docId}) does NOT
    // cover collectionGroup() queries that scan across all users — each collection
    // needs its own top-level {path=**} rule for the admin portal's cross-user reads.
    match /{path=**}/attendance/{docId} {
      allow read: if isLoggedIn() && (isAdmin() || canReadAttendance());
    }
    match /{path=**}/material_requests/{docId} {
      allow read: if isLoggedIn() && (isAdmin() || canAccessSubmissions());
    }
    match /{path=**}/material_purchases/{docId} {
      allow read: if isLoggedIn() && (isAdmin() || canAccessSubmissions());
    }
    match /{path=**}/material_transfers/{docId} {
      allow read: if isLoggedIn() && (isAdmin() || canAccessSubmissions());
    }
    match /{path=**}/tool_transfers/{docId} {
      allow read: if isLoggedIn() && (isAdmin() || canAccessSubmissions());
    }
    match /{path=**}/work_progress/{docId} {
      allow read: if isLoggedIn() && (isAdmin() || canAccessSubmissions());
    }
    // Required for getCompensationMap() which does collectionGroup("compensation").
    // Read-only and identically scoped to the per-doc rule — a looser collectionGroup
    // rule is a second door that defeats the per-doc one (see attendance_status above).
    match /{path=**}/compensation/{docId} {
      allow read: if isLoggedIn() && (isAdmin() || canAccessSettlements());
    }
    // Admin-only history read for the Daily Activity page (getAttendanceCorrectionsForDate).
    match /{path=**}/attendance_corrections/{docId} {
      allow read: if isLoggedIn() && isAdmin();
    }
    // READ-ONLY on purpose. A collectionGroup match cannot bind {userId}, so it cannot
    // enforce notSelf — granting write here reopened exactly the self-approval hole the
    // per-doc rule closes (caught by the rules suite). Writes must go through
    // /users/{userId}/attendance_status/{date}, which knows whose record it is.
    // The portal only ever writes to a known user path, so nothing legitimate needs this.
    match /{path=**}/attendance_status/{date} {
      allow read: if isLoggedIn() && (isAdmin() || canReadAttendanceStatus());
    }
    // Required for getPlannedHoursForMonth() which does collectionGroup("planned_hours").
    // The specific /users/{userId}/planned_hours/{date} match above authorizes the
    // per-doc write, but a collectionGroup READ needs this {path=**} rule.
    match /{path=**}/planned_hours/{date} {
      allow read: if isLoggedIn() && (isAdmin() || canReadPlannedHours());
    }
    // Required for getOtApprovalsForDateRange() which does collectionGroup("ot_approvals").
    match /{path=**}/ot_approvals/{date} {
      allow read: if isLoggedIn() && (isAdmin() || canReadOtApprovals());
    }
    // Required for getSettlementsForMonth() which does collectionGroup("settlements").
    match /{path=**}/settlements/{month} {
      allow read: if isLoggedIn() && (isAdmin() || canAccessSettlements());
    }
    // Collection-group read for daily_hours (admin reporting / future dashboards).
    match /{path=**}/daily_hours/{date} {
      allow read: if isLoggedIn() && (isAdmin() || canReadDailyHours());
    }
    match /{path=**}/regularization_requests/{docId} {
      allow read:   if isLoggedIn() && (isAdmin() || canAccessRegularization());
      allow update: if isLoggedIn() && (isAdmin() || (canAccessRegularization() && notSelfDoc()));
    }

    // ── /sent_notifications/{docId} — Notification send log ─────────────
    match /sent_notifications/{docId} {
      allow read, write: if isLoggedIn() && (isAdmin() || canAccessNotifications());
    }

    // ── /submission_edits/{docId} — Audit log for admin edits ────────────
    match /submission_edits/{docId} {
      allow read, write: if isLoggedIn() && (isAdmin() || canAccessSubmissions());
    }

    // ── /sites/{siteId} — Site management ────────────────────────────────
    match /sites/{siteId} {
      allow read:             if isLoggedIn();
      allow create, update:   if isLoggedIn() && isAdmin();
      allow delete:           if isLoggedIn() && isAdmin();
    }

    // ── /holidays/{date} — Company-wide holidays ────────────────────────
    // Any signed-in user may read (employees see holidays in their app); an admin
    // or a manager holding Attendance may mark/unmark. A marked day is skipped like a
    // Sunday by the nightly computeDailyAttendanceStatus function.
    match /holidays/{date} {
      allow read:  if isLoggedIn();
      allow write: if isLoggedIn() && (isAdmin() || canWriteHolidays());
    }

    // ── /config/{docId} — App configuration (conveyance rates, etc.) ────
    // Read also allowed for a Conveyance manager (rate lookup); write stays admin-only.
    match /config/{docId} {
      allow read:  if isLoggedIn() && (isAdmin() || canAccessConveyance());
      allow write: if isLoggedIn() && isAdmin();
    }

    // ── /conveyance/{docId} — Monthly conveyance records ────────────────
    match /conveyance/{docId} {
      allow read:  if isLoggedIn() && (isAdmin() || canAccessConveyance());
      allow write: if isLoggedIn() && (isAdmin() || canAccessConveyance());
    }
  }
}
