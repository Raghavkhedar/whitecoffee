<?xml version="1.0" encoding="utf-8"?><!--
   Data extraction rules (API 31+).
   wc_session holds the user identity + active session token — exclude it from both
   cloud backup and device-to-device transfer so credentials never leave the device.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="wc_session.xml"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="wc_session.xml"/>
    </device-transfer>
</data-extraction-rules>
